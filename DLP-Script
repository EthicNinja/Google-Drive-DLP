        </p>
        <hr>
        <h3>Aktivitas Terbaru (${activities.length}):</h3>
  `;

  activities.forEach((a, i) => {
    htmlBody += `
      <div style="padding:10px;background:#fff8f0;border-left:4px solid #e67e22;margin-bottom:10px;border-radius:4px;">
        <p style="margin:0;"><b>#${i + 1}</b> &mdash; ${a.who}</p>
