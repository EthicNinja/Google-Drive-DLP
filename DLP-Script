// ============================================================
// KONFIGURASI
// ============================================================
const CONFIG = {
  ADMIN_EMAIL: 'contoh@perusahaan.com',
  YOUR_DOMAIN: '@perusahaan.com',
  SCAN_INTERVAL_MINUTES: 5,
  ACTIVITY_CHECK_INTERVAL_MINUTES: 15,
  CLEANUP_DAYS: 30,         // Hapus flag file yang lebih dari X hari
  AUTO_REVOKE: false        // true = auto-block sharing, false = alert saja
};


// ============================================================
// SETUP TRIGGER - Jalankan sekali saja
// ============================================================
function createTrigger() {
  ScriptApp.getProjectTriggers().forEach(t => ScriptApp.deleteTrigger(t));

  ScriptApp.newTrigger('scanNewFiles')
    .timeBased()
    .everyMinutes(CONFIG.SCAN_INTERVAL_MINUTES)
    .create();

  ScriptApp.newTrigger('scanFileActivity')
    .timeBased()
    .everyMinutes(CONFIG.ACTIVITY_CHECK_INTERVAL_MINUTES)
    .create();

  ScriptApp.newTrigger('cleanOldFlaggedFiles')
    .timeBased()
    .onWeekDay(ScriptApp.WeekDay.MONDAY)  // <- tambahkan ini
    .atHour(1)                             // <- jam 1 pagi
    .create();

  Logger.log('Trigger aktif:');
  Logger.log('  scanNewFiles() setiap ' + CONFIG.SCAN_INTERVAL_MINUTES + ' menit');
  Logger.log('  scanFileActivity() setiap ' + CONFIG.ACTIVITY_CHECK_INTERVAL_MINUTES + ' menit');
  Logger.log('  cleanOldFlaggedFiles() setiap Senin jam 01.00 WIB');
}


// ============================================================
// UTILITY: Lihat trigger aktif
// ============================================================
function listActiveTriggers() {
  const triggers = ScriptApp.getProjectTriggers();

  if (triggers.length === 0) {
    Logger.log('Tidak ada trigger aktif.');
    return;
  }

  triggers.forEach((trigger, index) => {
