        <p style="margin:4px 0 0;color:#666;font-size:13px;">Waktu: ${a.time} WIB</p>
      </div>
    `;
  });

  htmlBody += `
        <hr>
        <p style="color:#888;font-size:12px;">
          Dikirim otomatis oleh Google Drive DLP Scanner &mdash; Ethic Ninja
        </p>
      </div>
    </div>
  `;

  GmailApp.sendEmail(
    CONFIG.ADMIN_EMAIL,
    '[Activity Alert] File sensitif "' + file.name + '" diakses',
    'Buka email ini dengan HTML viewer untuk melihat detail.',
    { htmlBody }
  );
}


