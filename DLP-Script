  let htmlBody = `
    <div style="font-family:Arial,sans-serif;max-width:700px;">
      <div style="background:#e67e22;padding:16px 20px;border-radius:6px 6px 0 0;">
        <h2 style="color:white;margin:0;">[Activity Alert] File Sensitif Diakses</h2>
      </div>
      <div style="border:1px solid #ddd;border-top:none;padding:20px;border-radius:0 0 6px 6px;">
        <p><b>Waktu deteksi:</b> ${timestamp} WIB</p>
        <p><b>File:</b> <a href="https://drive.google.com/file/d/${file.id}">${file.name}</a></p>
        <p style="color:#666;font-size:13px;">ID: ${file.id}</p>
        <p style="color:#666;font-size:13px;">
